# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public app URL (no trailing slash). Used for OAuth and webhook redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Web Push (VAPID). Generate once with:
#   npx web-push generate-vapid-keys
# Then paste the public key into NEXT_PUBLIC_VAPID_PUBLIC_KEY and the private key
# into VAPID_PRIVATE_KEY. VAPID_SUBJECT is your contact (mailto: or https://).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Cron secret for /api/cron/reminders. Set to any long random string.
# On Vercel, the platform sends "x-vercel-cron: 1" automatically; this fallback
# is only needed if you also trigger the route from your own scheduler.
CRON_SECRET=

# Anthropic API key — powers the "Scan receipt" feature on the Add Expense form.
# Optional. Without it the form still works (manual entry); the Scan button
# returns a friendly error. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=
